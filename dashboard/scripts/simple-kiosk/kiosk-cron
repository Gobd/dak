WAYLAND_DISPLAY=wayland-0
XDG_RUNTIME_DIR=/run/user/1000
# Screen on at 7am Tuesday and Thursday
0 7 * * 2,4 echo "on 0" | cec-client -s -d 1 2>/dev/null; /usr/bin/wlr-randr --output HDMI-A-1 --on 2>/dev/null
# Screen off at 6pm every day
0 18 * * * echo "standby 0" | cec-client -s -d 1 2>/dev/null; /usr/bin/wlr-randr --output HDMI-A-1 --off 2>/dev/null
